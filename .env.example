# MT5 Data Service Configuration
# Copy this to .env and fill in your values

# Database connection (NAS PostgreSQL)
DATABASE_URL=postgresql://tradelog:your_password@192.168.1.XXX:5432/tradelog

# Service settings
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Encryption key for broker credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_generated_fernet_key_here

# CORS - TradeLog app origin
CORS_ORIGINS=["http://192.168.1.XXX:3000","https://fbs.synology.me"]

# MT5 settings
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_MAX_CONCURRENT_DOWNLOADS=2
MT5_CHUNK_SIZE=100000

# Logging
LOG_LEVEL=INFO
